#!/usr/bin/env bash

set -eo pipefail

none() {
	echo 'Running CLJS test in Node with optimizations :none'
	TEST_SCI=true clojure -M:test:cljs-test-runner:sci:test-sci -c '{:optimizations :none}' "$@"
}

advanced() {
	echo 'Running CLJS test in Node with optimizations :advanced'
	TEST_SCI=true clojure -M:test:cljs-test-runner:sci:test-sci -c '{:optimizations :advanced :infer-externs true}' -e :simple "$@"
}

cherry-none() {
	echo 'Running CLJS test in Node with cherry + optimizations :none'
	clojure -M:test:cljs-test-runner:cherry:test-cherry -c '{:optimizations :none}' "$@"
}

cherry-advanced() {
	echo 'Running CLJS test in Node with cherry + optimizations :advanced'
        # For some reason :infer-externs true breaks everything in the cherry case, but this minimal externs file works.
        clojure -M:test:cljs-test-runner:cherry:test-cherry -c '{:optimizations :advanced :externs ["cherry-externs.js"]}' -e :simple "$@"
}

case $1 in
	none) none ;;
	advanced) advanced ;;
	cherry-none) cherry-none ;;
	cherry-advanced) cherry-advanced ;;
	*) none; advanced; cherry-none; cherry-advanced ;;
esac
